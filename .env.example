# ---------------------------------------------------------------------------
# Rekados Merchant — environment example
# PUBLIC REPO: this file contains ONLY safe placeholders. Never commit real
# secrets. Copy to `.env` for local development (.env is gitignored).
#
# Auth tokens are issued by the backend as httpOnly, secure, sameSite cookies
# and are NEVER read by this app in JS — so there are no auth secrets here.
# ---------------------------------------------------------------------------

# Base URL of the shared rekados-backend (NestJS) API.
# Client uses this for all requests (credentials: 'include' for cookie auth).
# Keep in sync with the CSP connect-src in nuxt.config.ts.
NUXT_PUBLIC_API_BASE=http://localhost:3001/api/v1
